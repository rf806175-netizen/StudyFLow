# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway, Render, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=minha_chave_secreta_123
JWT_EXPIRES_IN=7d

# ─── Frontend ─────────────────────────────────────────────────────────────────
# In production, replace with your actual domain
FRONTEND_URL=http://localhost:5173

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys (use test keys for dev)
STRIPE_SECRET_KEY=sk_test_SUA_CHAVE_AQUI
STRIPE_WEBHOOK_SECRET=whsec_SUA_CHAVE_AQUI

# Create these prices in the Stripe Dashboard (Recurring billing)
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_SUA_ID_AQUI
STRIPE_PREMIUM_YEARLY_PRICE_ID=price_SUA_ID_AQUI
